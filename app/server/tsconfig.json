{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "es2020",
        "esModuleInterop": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
}